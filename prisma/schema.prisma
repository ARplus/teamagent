// TeamAgent 数据库模型
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 用户
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique  // 手机号（付款凭证，用于管理员按手机号充值）
  name          String?
  nickname      String?   // 昵称，用于 AI 识别（如"段段"、"小敏"）
  password      String    // bcrypt hashed
  avatar        String?
  isVirtual     Boolean   @default(false)  // true = 子Agent虚拟用户，无真实登录
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSeenAt    DateTime? // 用户最后在线时间（心跳更新，判断人类在线状态）

  // 关联
  agent         Agent?
  tasks         Task[]    @relation("TaskAssignee")
  createdTasks  Task[]    @relation("TaskCreator")
  workspaces    WorkspaceMember[]
  apiTokens     ApiToken[]
  taskSteps     TaskStep[]
  attachments   Attachment[]
  submissions   StepSubmission[] @relation("SubmissionSubmitter")

  // NextAuth
  accounts      Account[]
  sessions      Session[]
  
  // 通知
  notifications Notification[]
  invitesSent     InviteToken[] @relation("InvitesSent")
  invitesReceived InviteToken[] @relation("InvitesReceived")
  
  // 聊天
  chatMessages  ChatMessage[]

  // 步骤评论
  stepComments  StepComment[]

  // B08: 多人指派
  stepAssignments StepAssignee[]
  // B12: 评分
  evaluationsReceived TaskEvaluation[] @relation("EvaluationMember")
  // F04: 任务编辑历史
  taskEdits TaskEditHistory[]
  // F06: 通知偏好
  preference UserPreference?
  // 任务模板
  taskTemplates     TaskTemplate[] @relation("TemplateCreator")

  // LLM 代理额度
  creditBalance     Int      @default(0)    // 积分余额
  activationCodesUsed ActivationCode[] @relation("ActivationCodeUser")
  llmUsageLogs      LlmUsageLog[]    @relation("LlmUsageLogs")

  // 支付订单
  paymentOrders     PaymentOrder[]
  // 日程
  scheduleEvents    ScheduleEvent[]
  // 龙虾学院：课程报名
  courseEnrollments  CourseEnrollment[]
  // 龙虾学院：考试提交
  examSubmissions   ExamSubmission[]
  // 龙虾学院：评论 & 点赞
  courseComments    CourseComment[] @relation("CourseCommentAuthor")
  courseLikes      CourseLike[]    @relation("CourseLikeUser")
  // 频道消息
  channelMessages  ChannelMessage[]
  // 工作区文档
  uploadedDocuments WorkspaceDocument[]
}

// AI Agent - 独立的数字公民，可被人类认领
model Agent {
  id          String   @id @default(cuid())
  name        String   // Agent 名字
  personality String?  // 性格描述
  avatar      String?  // Agent 头像
  status      String   @default("online") // online, working, waiting, offline
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 🆕 Agent-First 注册
  clawdbotId      String?   @unique  // Clawdbot 实例 ID（外部身份）
  pairingCode     String?   @unique  // 6位配对码
  pairingCodeExpiresAt DateTime?     // 配对码过期时间
  claimedAt       DateTime?          // 被认领时间
  
  // 绑定用户（认领后才有）
  userId      String?   @unique      // 🆕 改为可选
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 是否是用户的主Agent（总指挥）
  isMainAgent     Boolean  @default(false)

  // 🆕 Agent 独立能力
  capabilities    String?  // JSON: ["coding", "writing", "analysis"]
  workHistory     String?  // JSON: 工作历史统计
  reputation      Float?   @default(0)  // 信誉分 (0-5)

  // 🆕 军团成长系统 (Phase 0)
  soul            String?           // SOUL.md 内容（人格核心、说话风格、能力描述）
  growthXP        Int      @default(0)   // 成长经验值
  growthLevel     Int      @default(1)   // 当前等级 (1-5)

  // 🆕 新兵训练营
  onboardingStatus String  @default("graduated")  // training | graduated（已有Agent默认毕业）

  // 🆕 Claim 后临时存原始 Token，Agent 轮询取走即删
  pendingApiToken String?

  // 心跳：Agent Worker 每 60s ping 一次，用于判断在线状态
  lastHeartbeatAt DateTime?

  // 归属链：子Agent → 主Agent（B06）
  parentAgentId   String?
  parentAgent     Agent?   @relation("AgentHierarchy", fields: [parentAgentId], references: [id])
  childAgents     Agent[]  @relation("AgentHierarchy")

  @@index([pairingCode])
  @@index([clawdbotId])
}

// API Token - 让 Skill 能安全调用 API
model ApiToken {
  id            String   @id @default(cuid())
  token         String   @unique  // 实际 token 值（hash 后存储）
  name          String   // token 名称，如 "Lobster Skill"
  displayToken  String?  // 明文 token（仅管理员充值自动生成的会填此字段，供用户在设置页查看）
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  // 绑定用户
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 工作区
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 工作区配置 JSON: { decomposerType: "hub-llm" | "main-agent" }
  settings    String?
  // 龙虾学院：工作区类型
  type        String    @default("normal")  // normal | organization
  orgType     String?                       // academy | enterprise | studio（组织子类型，展示用）
  orgName     String?                       // 组织显示名称（如"北京大学"，不填则用工作区名）
  orgLogo     String?                       // 组织 logo URL

  // 关联
  members     WorkspaceMember[]
  tasks       Task[]
  invites     InviteToken[]
  taskTemplates      TaskTemplate[]
  channels    Channel[]
  documents   WorkspaceDocument[]
}

// 邀请 Token（分享链接核心）
model InviteToken {
  id          String    @id @default(cuid())
  token       String    @unique
  role        String    @default("member")
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  inviterId   String
  inviter     User      @relation("InvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)

  // 接受邀请的人（接受时记录，永久保存任务可见性）
  inviteeId   String?
  invitee     User?     @relation("InvitesReceived", fields: [inviteeId], references: [id], onDelete: SetNull)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  taskId      String?
  task        Task?     @relation("TaskInvites", fields: [taskId], references: [id], onDelete: SetNull)

  // Team 模版多方邀请：记录被邀请方的角色（用于接受后自动绑定步骤）
  partyRole   String?  // "party-a" | "party-b" | 自定义

  @@index([token])
  @@index([inviteeId, taskId])
}

// 工作区成员
model WorkspaceMember {
  id            String    @id @default(cuid())
  role          String    @default("member") // owner, admin, member
  joinedAt      DateTime  @default(now())
  memberSource  String?   // invite | invite_link | system_init | agent_register | manual | unknown
  addedByUserId String?   // 谁添加的（User.id），历史数据可能为空

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// 任务
model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("todo") // suggested, todo, in_progress, review, done
  priority    String   @default("medium") // low, medium, high, urgent
  mode        String   @default("solo")   // solo（AI团队内部）| team（外部人类协作）
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ⏱️ 工作量统计
  totalAgentTimeMs  Int?    // 总 Agent 执行时间（毫秒）
  totalHumanTimeMs  Int?    // 总人类审批时间（毫秒）
  agentWorkRatio    Float?  // Agent 工作占比 (0-1)

  // F04: 补充说明（任务开始后追加的内容）
  supplement        String?  // 补充说明文本（Markdown）

  // A2A 协议追踪
  traceId           String?  // 跨事件追踪链路 ID

  // 可插拔拆解状态
  decomposeStatus   String?  // null | "pending" | "fallback" | "done"
  decomposeEngine   String?  // "main-agent" | "hub-claude" | "hub-qwen"

  // 审批门控：模版 requiresApprovalGate=true 时，pre_check 步骤通过前对其他参与方不可见
  isApproved        Boolean  @default(true)

  // 任务完成总结
  autoSummary       String?  // 系统自动生成的完成摘要
  creatorComment    String?  // 发起者结语（人类填写）

  // 创建者
  creatorId   String
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id])

  // 执行者
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // 所属工作区
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 前置任务（历史上下文）
  parentTaskId String?
  parentTask   Task?    @relation("TaskHistory", fields: [parentTaskId], references: [id])
  childTasks   Task[]   @relation("TaskHistory")

  // 工作流步骤
  steps       TaskStep[]
  invites     InviteToken[] @relation("TaskInvites")
  
  // 任务级附件（参考资料、背景文档）
  attachments Attachment[]

  // B12: 评分
  evaluations   TaskEvaluation[]

  // 通知
  notifications Notification[]

  // F04: 编辑历史
  editHistory TaskEditHistory[]

  // 模板关联（从模板创建的实例）
  templateId      String?
  template        TaskTemplate? @relation("TemplateInstances", fields: [templateId], references: [id], onDelete: SetNull)
  instanceNumber  Int?     // 第几次执行（#1, #2, #3...）

  // 多方参与配置（Team 模版运行时存储 parties 绑定关系）
  // JSON 格式：[{ role, label, bindType, orgName?, agentId?, userId?, materials? }]
  parties         Json?

  // 日程关联
  scheduleEvents  ScheduleEvent[]
  // 龙虾学院：课程报名（一个课程实例对应一个报名记录）
  courseEnrollment CourseEnrollment?
}

// 任务步骤 - 工作流节点
model TaskStep {
  id          String   @id @default(cuid())
  title       String   // 步骤标题
  description String?  // 步骤说明
  order       Int      // 步骤顺序
  
  // 步骤类型
  stepType    String   @default("task")  // task | meeting | decompose

  // 并行分组（同一 parallelGroup 的步骤可同时执行，不等上一步）
  parallelGroup String?  // null = 顺序执行；相同字符串 = 并行组

  // 责任人（支持多人显示）
  assigneeNames String?  // JSON: ["小敏", "段段"] 用于显示
  assigneeId    String?  // 主责任人用户ID（向后兼容）
  assignee      User?    @relation(fields: [assigneeId], references: [id])

  // B08: 多人指派
  assignees      StepAssignee[]
  completionMode String  @default("all")  // "all" = 全部完成 | "any" = 任一完成
  
  // 会议专用字段
  scheduledAt  DateTime?  // 会议时间
  agenda       String?    // 会议议程（Markdown）
  participants String?    // JSON: ["小敏", "段段", "Aurora"] 所有参会人名

  // 输入输出
  inputs      String?  // JSON: ["需要的输入"]
  outputs     String?  // JSON: ["产出物"]
  skills      String?  // JSON: ["需要的Skill"]
  
  // 审批设置
  requiresApproval Boolean @default(true)  // false = Agent 提交后自动通过，无需人工审批

  // 状态
  status      String   @default("pending") // pending, in_progress, waiting_approval, done, rejected
  agentStatus String?  // online, pending, working, waiting_approval, blocked, offline
  
  // 结果
  result      String?  // 步骤结果/产出描述
  summary     String?  // AI 生成的摘要
  
  // 审核
  approvedAt  DateTime?
  approvedBy  String?
  rejectedAt  DateTime?
  rejectionReason String?
  
  // 申诉机制
  appealText       String?   // Agent 的申诉理由
  appealStatus     String?   // null | "pending" | "upheld" | "dismissed"
  appealedAt       DateTime? // 申诉时间
  appealResolvedAt DateTime? // 申诉裁定时间
  
  // ⏱️ 工作量追踪
  rejectionCount   Int      @default(0)  // 被打回次数
  agentDurationMs  Int?     // Agent 执行耗时（毫秒）
  humanDurationMs  Int?     // 人类审批耗时（毫秒）
  agentMetrics     Json?    // Watch 上报的精细统计 {durationMs, promptChars, resultChars, assigneeName}
  
  // 时间戳
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  reviewStartedAt DateTime?  // 人类开始审批时间

  // ── V1.1 步骤展开（子步骤机制）──
  parentStepId    String?
  parentStep      TaskStep?  @relation("StepExpansion", fields: [parentStepId], references: [id])
  childSteps      TaskStep[] @relation("StepExpansion")

  // ── V1.1 人类资料补充 ──
  needsHumanInput    Boolean  @default(false)
  humanInputPrompt   String?  @db.Text
  humanInputStatus   String?  @default("not_needed") // waiting | provided | not_needed

  // ── V1.1 未分配步骤 ──
  unassigned         Boolean  @default(false)
  unassignedReason   String?

  // ── Team 模版多方参与 ──
  partyRole          String?  // "party-a" | "party-b" | 自定义角色名，用于邀请方加入后自动绑定

  // 所属任务
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // 附件
  attachments Attachment[]

  // 提交历史
  submissions StepSubmission[]

  // 评论
  comments    StepComment[]

  // 通知
  notifications Notification[]

  // 工作区文档（步骤提交时生成的文档）
  outputDocuments WorkspaceDocument[]

  @@index([assigneeId, status])  // Solo Mode 高频查询优化（CodeReviewer 建议）
  @@index([taskId, order])
  @@index([parentStepId])
}

// 步骤提交记录 - 每次提交都是一条新记录，保留历史
model StepSubmission {
  id          String   @id @default(cuid())
  
  // 提交内容
  result      String   // 提交的结果
  summary     String?  // AI 摘要
  
  // 审核状态
  status      String   @default("pending") // pending, approved, rejected
  reviewedAt  DateTime?
  reviewedBy  String?   // 审核人 ID
  reviewNote  String?   // 审核备注（通过/拒绝的说明）
  
  // 时间
  createdAt   DateTime @default(now())
  
  // 执行耗时
  durationMs  Int?     // 这次提交的执行时间
  
  // 关联
  stepId      String
  step        TaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  
  submitterId String
  submitter   User     @relation("SubmissionSubmitter", fields: [submitterId], references: [id])
  
  // 附件
  attachments Attachment[]
}

// 附件
model Attachment {
  id          String   @id @default(cuid())
  name        String   // 文件名
  url         String   // 文件 URL 或路径
  type        String?  // 文件类型 (mime type)
  size        Int?     // 文件大小 (bytes)
  createdAt   DateTime @default(now())

  // 所属任务（任务级背景文档）
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // 所属步骤（直接附件）
  stepId      String?
  step        TaskStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)
  
  // 所属提交记录（提交时的附件）
  submissionId String?
  submission   StepSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // 所属评论（评论附件）
  commentId   String?
  comment     StepComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  // 上传者
  uploaderId  String
  uploader    User     @relation(fields: [uploaderId], references: [id])

  // V1.1: 上传者类型（文件权限控制）
  uploaderType String?  // "agent" | "human"
}

// 站内通知
model Notification {
  id          String   @id @default(cuid())
  type        String   // task_assigned, step_waiting, step_approved, step_rejected, task_completed, mention, agent_call
  title       String
  content     String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  // F06: 优先级 + 呼叫状态
  priority    String   @default("normal")  // urgent, normal, low
  callStatus  String?  // null=普通通知, pending=等待回复, accepted=已接受, declined=已拒绝
  respondedAt DateTime?

  // 接收者
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 关联的任务（可选）
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // 关联的步骤（可选）
  stepId      String?
  step        TaskStep? @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([userId, callStatus])
}

// F06: 用户通知偏好（免打扰等）
model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 免打扰设置
  dndEnabled    Boolean  @default(false)
  dndStart      String?  // HH:mm 格式，如 "22:00"
  dndEnd        String?  // HH:mm 格式，如 "08:00"

  // 通知级别过滤：只推送指定优先级以上的通知
  minPriority   String   @default("low")  // "urgent" = 只推送紧急, "normal" = 推送普通+紧急, "low" = 全部

  // 审批呼叫是否弹窗提醒
  callPopupEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// ============ NextAuth 相关表 ============

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 🆕 聊天消息 - 用户与 Agent 的对话
model ChatMessage {
  id          String   @id @default(cuid())
  content     String   // 消息内容
  role        String   // "user" | "agent"
  createdAt   DateTime @default(now())
  
  // 关联用户
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 关联 Agent（可选，agent 回复时填）
  agentId     String?
  
  // 元数据（语音输入、附带操作等）
  metadata    String?  // JSON: { voice: true, action: "create_task", ... }

  @@index([userId, createdAt])
}

// B08: 步骤多人指派 - 一个步骤可分配给多人（人类+Agent混合）
model StepAssignee {
  id            String   @id @default(cuid())

  // 所属步骤
  stepId        String
  step          TaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  // 被指派的用户
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  // 角色区分
  assigneeType  String   @default("agent")   // "agent" | "human"
  isPrimary     Boolean  @default(false)      // 主负责人（向后兼容 assigneeId）

  // 每人完成状态
  status        String   @default("pending")  // pending | submitted | done
  submittedAt   DateTime?
  result        String?  // 该成员的提交结果

  createdAt     DateTime @default(now())

  @@unique([stepId, userId])  // 同一步骤不重复分配同一人
  @@index([userId, status])   // 我的待办查询
  @@index([stepId])
}

// 🆕 步骤评论 - 人类与 Agent 在步骤中的自由讨论
model StepComment {
  id          String   @id @default(cuid())
  content     String   // 评论内容
  isFromAgent Boolean  @default(false) // true = Agent 通过 API Token 发的评论
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 所属步骤
  stepId      String
  step        TaskStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  // 评论者
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  // 附件
  attachments Attachment[]

  @@index([stepId, createdAt])
}

// B12: 任务完成评分
model TaskEvaluation {
  id            String   @id @default(cuid())
  taskId        String
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  memberId      String   // 被评分的成员 userId
  member        User     @relation("EvaluationMember", fields: [memberId], references: [id])
  memberName    String?  // 被评分者名字（冗余，方便展示）
  memberType    String   @default("agent") // "agent" | "human"

  // 评分维度 (1-5)
  quality       Float    // ⭐ 质量分
  efficiency    Float    // ⏱️ 效率分
  collaboration Float    // 🤝 协作分
  overallScore  Float    // 📊 综合分（加权平均）
  comment       String?  // 💬 一句话点评

  // 评分统计依据
  stepsTotal    Int      @default(0)  // 该成员负责步骤总数
  stepsDone     Int      @default(0)  // 已完成步骤数
  avgDurationMs Int?     // 平均步骤耗时

  // 元信息
  evaluatedBy   String?  // 评分执行者（Agent userId 或 "system"）
  model         String?  // 使用的 LLM 模型
  createdAt     DateTime @default(now())

  @@unique([taskId, memberId])
  @@index([taskId])
  @@index([memberId])
}

// F04: 任务编辑历史
model TaskEditHistory {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  editorId    String
  editor      User     @relation(fields: [editorId], references: [id])
  editType    String   // "full_edit" | "supplement" — 全量编辑 / 补充说明
  fieldName   String   // 修改的字段名: "title" | "description" | "priority" | "dueDate" | "supplement"
  oldValue    String?  // 修改前的值
  newValue    String?  // 修改后的值
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([editorId])
}

// 任务模板（模版 = Skill 编排 + Prompt 模板 + 变量槽位）
model TaskTemplate {
  id              String   @id @default(cuid())

  // ── 基本信息 ──
  name            String                  // 模版名称（如"AI+康养资讯简报"）
  description     String?                 // 模版用途说明
  icon            String?                 // emoji 图标（如 "📰"）
  category        String   @default("general")  // general, research, report, creative, ops
  tags            String?                 // JSON: ["AI", "康养", "资讯"] 用于搜索

  // ── 归属 ──
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorId       String
  creator         User      @relation("TemplateCreator", fields: [creatorId], references: [id])

  // ── 来源 ──
  sourceTaskId    String?                 // 从哪个成功任务保存的（可选）
  sourceType      String   @default("manual")  // manual | from-task | agent-created

  // ── 执行规范层（V1.1）──
  // 所有步骤共享的"怎么做好"方法论，run 时与 promptTemplate 拼接为 step.description
  executionProtocol String?  @db.Text

  // ── 变量定义 ──
  // JSON: [{ name, label, type, default?, required, description?, options? }]
  variables       String   @default("[]")

  // ── 步骤模板 ──
  // JSON: [{ order, title, promptTemplate?, assigneeRole, requiredSkills?, requiresApproval, parallelGroup, ... }]
  stepsTemplate   String

  // ── 任务默认配置 ──
  defaultMode     String   @default("solo")    // solo | team
  defaultPriority String   @default("medium")

  // ── 调度（可选，null = 手动触发） ──
  schedule        String?                 // cron 表达式: "0 9 * * 5"
  timezone        String   @default("Asia/Shanghai")
  scheduleEnabled Boolean  @default(false)

  // 审批门控：true 时从模版创建任务后，pre_check 通过前对其他参与方不可见
  requiresApprovalGate  Boolean  @default(false)

  // ── 兼容旧字段（迁移过渡） ──
  approvalMode    String   @default("every")   // every | on_error | auto
  deliveryBoard   Boolean  @default(true)
  deliveryChat    Boolean  @default(false)
  deliveryEmail   Boolean  @default(false)
  deliveryFile    Boolean  @default(false)

  // ── 可见性 ──
  isDraft         Boolean  @default(false)     // true = 草稿，仅创建者/admin可见
  isPublic        Boolean  @default(true)      // 保留向后兼容（以 visibility 为准）
  visibility      String   @default("workspace") // public | workspace | private
  isEnabled       Boolean  @default(true)      // false = 已归档

  // ── 统计 ──
  useCount        Int      @default(0)         // 被使用次数
  lastUsedAt      DateTime?
  lastRunAt       DateTime?                    // 定时执行时间
  nextRunAt       DateTime?
  runCount        Int      @default(0)
  failCount       Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── 龙虾学院：课程字段 ──
  price           Int?                        // Token 价格（null=免费）
  courseType      String?                     // agent | human | both（null=普通模板，非课程）
  reviewStatus    String   @default("none")   // none | pending | approved | rejected
  reviewNote      String?                     // 审核意见
  coverImage      String?                     // 封面图 URL
  school          String?                     // 发布学校/机构（如"北京大学"、"龙虾学院"）
  department      String?                     // 院系/专业/行业（如"计算机科学"、"AI"、"金融"）
  difficulty      String?                     // 学习难度：beginner | intermediate | advanced

  // ── 龙虾学院：考试 ──
  // JSON: { passScore, questions: [{ id, type, title, points, options?, correctAnswer?, referenceAnswer?, uploadHint? }] }
  examTemplate    String?  @db.Text           // 考试定义（null = 无考试）
  examPassScore   Int      @default(60)       // 及格分（0-100）

  // ── 龙虾学院：Principle 百宝箱 ──
  principleTemplate  String?  @db.Text        // 出题老师提交的 Principle 草稿（Markdown）
  principleRequired  Boolean  @default(true)  // 是否必须提交 Principle 才能发布（课程默认必须）

  // ── 关联 ──
  instances       Task[]   @relation("TemplateInstances")
  enrollments     CourseEnrollment[]
  examSubmissions ExamSubmission[]
  comments        CourseComment[]
  likes           CourseLike[]

  @@map("ScheduledTemplate")
  @@index([workspaceId, category])
  @@index([workspaceId, isEnabled])
  @@index([scheduleEnabled, nextRunAt])
}

// 激活码（管理员生成，用户兑换积分）
model ActivationCode {
  id              String    @id @default(cuid())
  code            String    @unique        // 8字符激活码 (大写+数字，排除 O/0/I/1)
  credits         Int                      // 兑换后获得的积分
  expiresAt       DateTime                 // 过期时间

  // 使用状态
  usedAt          DateTime?
  usedByUserId    String?
  usedByUser      User?     @relation("ActivationCodeUser", fields: [usedByUserId], references: [id], onDelete: SetNull)

  // 管理信息
  createdAt       DateTime  @default(now())
  createdByEmail  String                   // 生成者邮箱 (admin)
  note            String?                  // 备注（如"微信付款 ¥99"）

  @@index([code])
}

// LLM 使用日志（积分消费记录）
model LlmUsageLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("LlmUsageLogs", fields: [userId], references: [id], onDelete: Cascade)

  model           String                   // "qwen-max-latest" | "qwen-turbo"
  promptTokens    Int
  completionTokens Int
  totalTokens     Int
  creditsDeducted Int                      // 实际扣除积分

  requestSource   String?                  // "openclaw" | "api"

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
}

// 支付订单（支付宝）
model PaymentOrder {
  id            String    @id @default(cuid())
  outTradeNo    String    @unique          // 商户订单号 TA_xxx
  tradeNo       String?                    // 支付宝交易号
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  planId        String                     // 套餐ID: starter/pro/ultimate
  amount        Int                        // 金额（分）
  credits       Int                        // 对应积分
  status        String    @default("pending") // pending/paid/closed/refunded
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

// 日程事件
model ScheduleEvent {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String                          // 事件标题
  description String?                         // 详细描述
  emoji       String?   @default("📅")        // emoji 图标
  startAt     DateTime                        // 开始时间
  endAt       DateTime?                       // 结束时间（可选，全天事件无结束时间）
  allDay      Boolean   @default(false)       // 是否全天事件
  remindAt    DateTime?                       // 提醒时间（null=不提醒）
  reminded    Boolean   @default(false)       // 是否已发送提醒
  color       String?   @default("orange")    // 颜色标签: orange/blue/emerald/rose/purple
  taskId      String?                         // 关联任务（可选）
  task        Task?     @relation(fields: [taskId], references: [id])
  source      String    @default("manual")    // 创建来源: manual/voice/agent
  voiceText   String?                         // 语音原文（如果通过语音创建）
  recurring   String?                         // 重复规则: daily/weekly/monthly/null
  status      String    @default("active")    // active/completed/cancelled
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, startAt])
  @@index([userId, status])
  @@index([remindAt, reminded])
}

// V1.1: Skill 注册表（Hub 官方推荐 Skill 目录）
model SkillRegistry {
  id              String   @id @default(cuid())
  name            String   @unique             // Skill 名称，如 "tavily-search"
  description     String                       // Skill 用途描述
  clawhubPackage  String?                      // ClawHub 包名（clawhub install xxx）
  category        String   @default("general") // search, content, analysis, dev, general
  requiresKey     Boolean  @default(false)     // 是否需要 API Key
  keySetupGuide   String?  @db.Text            // Key 获取指南
  alternatives    String?                      // JSON: ["替代方案1", "替代方案2"]
  recommended     Boolean  @default(true)      // 是否推荐
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
}

// ══════════ 龙虾学院 ══════════

// 课程报名 — 连接学生与课程，追踪学习进度
model CourseEnrollment {
  id           String    @id @default(cuid())
  userId       String
  templateId   String
  status         String    @default("enrolled")  // enrolled | learning | completed | graduated
  progress       Int       @default(0)           // 0-100%
  completedSteps String?                         // JSON: [0,1,3] — 已完成的步骤索引（human课程用）
  taskId         String?   @unique               // 对应的 Task 实例（Agent课程=跑模板生成的任务）
  paidTokens     Int       @default(0)           // 支付的 Token 数
  enrolledByAgentId String?                      // 如果是 Agent 报名，记录 agentId（区分人类/Agent）
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?

  // Principle 下发
  principleDelivered   Boolean   @default(false)  // 是否已下发 Principle 到学员百宝箱
  principleDeliveredAt DateTime?                  // 下发时间

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     TaskTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  examSubmission ExamSubmission?

  @@unique([userId, templateId])
  @@index([templateId])
  @@index([userId])
}

// 考试提交记录
model ExamSubmission {
  id              String   @id @default(cuid())
  enrollmentId    String   @unique
  userId          String
  templateId      String

  // 答案: [{ questionId, answer, autoScore?, manualScore?, feedback? }]
  answers         String   @db.Text
  autoScore       Int?                        // 客观题自动得分
  manualScore     Int?                        // 主观题人工得分
  totalScore      Int?                        // 总分
  maxScore        Int      @default(100)      // 满分
  passed          Boolean  @default(false)

  // 批改状态
  gradingStatus   String   @default("pending")  // pending | auto_graded | manual_grading | graded
  gradedBy        String?                       // 阅卷人 userId
  gradingNote     String?                       // 阅卷备注

  // 投诉
  complaintText   String?  @db.Text
  complaintStatus String?                       // null | pending | resolved | dismissed
  complaintNote   String?                       // 仲裁备注

  // 人机共学
  matchedWith     String?                       // 搭档的 submissionId
  matchReport     String?  @db.Text             // 匹配报告 JSON

  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  enrollment      CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        TaskTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([gradingStatus])
}

// 龙虾学院：课程评论
model CourseComment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templateId  String
  template    TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  authorId    String
  author      User     @relation("CourseCommentAuthor", fields: [authorId], references: [id])

  @@index([templateId, createdAt])
}

// 龙虾学院：课程点赞
model CourseLike {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  templateId  String
  template    TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation("CourseLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([templateId])
}

// ══════════ 频道群聊 ══════════

// 工作区频道 — 多人+多Agent 群聊
model Channel {
  id          String   @id @default(cuid())
  name        String                          // 频道名（如"大厅"、"开发讨论"）
  slug        String                          // URL 友好标识（如"lobby"）
  description String?
  isDefault   Boolean  @default(false)        // 默认频道不可删除
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  messages    ChannelMessage[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

// 频道消息 — 支持人类和 Agent 发送
model ChannelMessage {
  id          String   @id @default(cuid())
  content     String   @db.Text
  createdAt   DateTime @default(now())

  // 发送者（人类 userId，Agent 也通过其绑定 user 发）
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])

  // Agent 标识
  isFromAgent Boolean  @default(false)
  agentId     String?                         // Agent 发送时填写
  agentName   String?                         // 冗余存储，免 join

  // 元数据：附件、@mention 等
  metadata    String?                         // JSON: { attachments: [...], mentions: [...] }

  // 所属频道
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
  @@index([senderId])
}

// 工作区文档协同（V1.5 MVP）
model WorkspaceDocument {
  id          String    @id @default(cuid())
  title       String                        // 文件标题（显示用）
  folder      String    @default("references") // decisions | requirements | references | outputs | principles
  content     String    @db.Text           // 文件内容（markdown/plain text/json）
  mimeType    String    @default("text/markdown") // text/markdown | text/plain | application/json
  fileSize    Int?                          // 字节数（近似）
  version     Int       @default(1)        // 版本号（同名文件更新时 +1）

  // 来源追踪
  sourceType  String?   // manual | step_submit | secretary | course_completion
  sourceStepId String?  // 来自哪个步骤提交（step_submit 时填）
  sourceStep  TaskStep? @relation(fields: [sourceStepId], references: [id], onDelete: SetNull)

  // 所属工作区
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // 上传者
  uploaderId  String
  uploader    User      @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, folder])
  @@index([workspaceId, createdAt])
  @@index([uploaderId])
}

// A2A 协议：幂等键记录（防重复写操作）
model IdempotencyRecord {
  id        String   @id @default(cuid())
  key       String   @unique         // 幂等键（客户端生成）
  method    String                    // HTTP 方法 (POST/PATCH)
  path      String                    // API 路径
  status    Int                       // 响应状态码
  body      String?  @db.Text        // 响应体 JSON
  createdAt DateTime @default(now())
  expiresAt DateTime                  // 过期时间（24h 后自动清理）

  @@index([expiresAt])
}
